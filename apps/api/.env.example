# --- 권장: Resend (Render Free에서 Gmail SMTP가 멈추는 경우가 많음) ---
# https://resend.com 가입 → API Keys → 발급
RESEND_API_KEY=
# 무료 테스트: onboarding@resend.dev (수신은 CONTACT_TO_EMAIL = Resend 가입 메일과 같아야 함)
