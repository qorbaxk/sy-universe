# --- 로컬 대안: SMTP (Gmail 앱 비밀번호) ---
# Render에서는 타임아웃/차단이 잦아 Resend를 우선 쓰세요.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=qorbaxk97@gmail.com
